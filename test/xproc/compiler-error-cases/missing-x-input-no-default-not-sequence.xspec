<?xml version="1.0" encoding="UTF-8"?>
<?xspec-test message=ERROR in x:call (under 'Missing x:input for port requiring a document'): Missing x:input for port 'in2', which requires a document.?>
<x:description xmlns:s="x-urn:test:xproc:steplibrary"
    xmlns:x="http://www.jenitennison.com/xslt/xspec" xproc="../cases/library-connections.xpl">
    <x:scenario label="Missing x:input for port requiring a document">
        <x:call step="s:two-inputs-no-option-one-output">
            <x:input port="in1">
                <in1/>
            </x:input>
            <!-- No x:input with port="in2" -->
        </x:call>
        <x:expect label="should raise an error" as="item()*"/>
    </x:scenario>
</x:description>
