<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:s="x-urn:test:xproc:steplibrary"
    xmlns:x="http://www.jenitennison.com/xslt/xspec" xproc="library-force-focus.xpl">

    <!--
        These scenarios test the force-focus option of XProc 3 harnesses.
        For corresponding scenario using XQS, see test/xqs/force-focus.xspec. 
    -->

    <x:import href="force-focus_import.xspec"/>
    <x:scenario label="Running XSpec test for XSLT">
        <x:call step="s:xslt-varying-force-focus"/>
        <x:like label="Check force-focus set to #none and a scenario identifier"/>
    </x:scenario>
    <x:scenario label="Running XSpec test for XQuery">
        <x:call step="s:xquery-varying-force-focus"/>
        <x:like label="Check force-focus set to #none and a scenario identifier"/>
    </x:scenario>
    <x:scenario label="Running XSpec test for XProc">
        <x:call step="s:xproc-varying-force-focus"/>
        <x:like label="Check force-focus set to #none and a scenario identifier"/>
    </x:scenario>

</x:description>
