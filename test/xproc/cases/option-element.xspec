<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:items="x-urn:test:xspec-items" xmlns:optinfo="x-urn:test:optinfo"
    xmlns:svg="http://www.w3.org/2000/svg" xmlns:x="http://www.jenitennison.com/xslt/xspec"
    xmlns:xs="http://www.w3.org/2001/XMLSchema" xproc="library-options.xpl">
    <x:helper stylesheet="../../items.xsl"/>

    <!-- For scenarios that use options with names in a namespace, see
        no-input-two-options-one-output.xspec -->

    <x:scenario label="x:option can specify a value using">
        <x:scenario label="embedded child nodes">
            <x:call step="optinfo:option-value">
                <x:option name="opt" as="element(document)"><document/></x:option>
            </x:call>
            <x:like label="verify result document"/>
            <x:like label="verify that node is an element"/>
        </x:scenario>
        <x:scenario label="embedded child nodes and @select to get an element">
            <x:call step="optinfo:option-value">
                <x:option name="opt" select="//document" as="element(document)">
                    <root>
                        <document/>
                    </root>
                </x:option>
            </x:call>
            <x:like label="verify result document"/>
            <x:like label="verify that node is an element"/>
        </x:scenario>
        <x:scenario label="embedded child nodes and @select to get a document node">
            <x:call step="optinfo:option-value">
                <x:option name="opt" select="/" as="document-node(element(document))">
                    <document/>
                </x:option>
            </x:call>
            <x:like label="verify result document"/>
            <x:like label="verify that node is a document node"/>
        </x:scenario>
        <x:scenario label="@href pointing to a generic XML document">
            <x:call step="optinfo:option-value">
                <x:option name="opt" href="document.xml" as="document-node(element(document))"/>
            </x:call>
            <x:like label="verify result document"/>
            <x:like label="verify that node is a document node"/>
        </x:scenario>
        <x:scenario label="@href pointing to an SVG document">
            <x:scenario label="Verify content">
                <x:call step="optinfo:option-value">
                    <x:option name="opt" href="document-image.svg"
                        as="document-node(element(svg:svg))"/>
                </x:call>
                <x:expect label="from the file" port="xproc-result">
                    <svg:svg x:attrs="...">...</svg:svg>
                </x:expect>
                <x:expect label="Content type is application/xml (loading happens in XSLT, not XProc)"
                    port="option-content-type" select="'application/xml'"/>
                <x:expect port="option-base-uri" test="substring-after(., 'test/xproc/cases/')"
                    select="'document-image.svg'">
                    <x:label>Base URI reflects the document, not .xsl or .xpl intermediate file</x:label>
                </x:expect>
            </x:scenario>
        </x:scenario>
        <x:scenario label="@href and @select to get an element">
            <x:call step="optinfo:option-value">
                <x:option name="opt" href="document.xml" select="/element()" as="element(document)"
                />
            </x:call>
            <x:like label="verify result document"/>
            <x:like label="verify that node is an element"/>
        </x:scenario>
        <x:scenario label="@href and @select to get a document node">
            <x:call step="optinfo:option-value">
                <x:option name="opt" href="document.xml" select="root()"
                    as="document-node(element(document))"/>
            </x:call>
            <x:like label="verify result document"/>
            <x:like label="verify that node is a document node"/>
        </x:scenario>
        <x:scenario label="@select alone to get an element">
            <x:call step="optinfo:option-value">
                <x:option name="opt" select="parse-xml('&lt;document/>')/*"
                    as="element(document)"/>
            </x:call>
            <x:like label="verify result document"/>
            <x:like label="verify that node is an element"/>
        </x:scenario>
        <x:scenario label="@select alone to get a document node">
            <x:call step="optinfo:option-value">
                <x:option name="opt" select="parse-xml('&lt;document/>')"
                    as="document-node(element(document))"/>
            </x:call>
            <x:like label="verify result document"/>
            <x:like label="verify that node is a document node"/>
        </x:scenario>
    </x:scenario>
    <x:scenario label="When opt is not provided in x:call">
        <x:call step="optinfo:option-value"/>
        <x:expect label="the option-value step returns the option's default value"
            port="xproc-result" select="'default'"/>
    </x:scenario>
    <x:scenario label="When opt is a sequence of nodes other than attribute and namespace nodes">
        <x:call step="optinfo:option-value">
            <x:option name="opt" select="$items:wrappable-nodes" as="node()+"/>
        </x:call>
        <x:expect port="xproc-result" result-type="node()+" test="count($x:result)"
            select="count($items:wrappable-nodes)">
            <x:label>the option-value step returns a sequence of nodes, one for each item in the
                original sequence. (They're document nodes due to wrapping at output port,
                but that's not the point.)</x:label>
        </x:expect>
        <x:expect port="node-type" label="the node types seen inside the step match"
            select="['comment','document node','document node','element','processing instruction','text']"/>
        <x:expect label="the comment node matches" port="xproc-result" test="$x:result/comment()"
            select="$items:wrappable-nodes[self::comment()]"/>
        <x:expect port="xproc-result" test="$x:result/element()" select="(
            $items:wrappable-nodes[self::document-node(element())]/element(),
            $items:wrappable-nodes[self::element()]
            )">
            <x:label>the element nodes match (the original element became wrapped in a document
                node)</x:label>
        </x:expect>
        <x:expect port="xproc-result" test="$x:result/text()" select="(
            $items:wrappable-nodes[self::document-node()]/text(),
            $items:wrappable-nodes[self::text()]
            )">
            <x:label>the two text nodes match (the original text node became wrapped in a document
                node)</x:label>
        </x:expect>
        <x:expect label="the PI node matches" port="xproc-result"
            test="$x:result/processing-instruction()"
            select="$items:wrappable-nodes[self::processing-instruction()]"/>
    </x:scenario>
    <x:scenario label="When x:option has multiple child nodes">
        <x:call step="optinfo:option-value">
            <x:option name="opt" as="node()+">
                <node1/>
                <!-- node2 -->
                <node3/>
                <?node4?>
                <x:text>node 5</x:text>
            </x:option>
        </x:call>
        <x:expect port="xproc-result" result-type="document-node()+" test="count($x:result)"
            select="5">
            <x:label>the option-value step returns a sequence of document nodes, one for each item
                in the original sequence. (Wrapping is done at output port.)</x:label>
        </x:expect>
        <x:expect port="node-type" label="the node types match"
            select="['element','comment','element','processing instruction','text']"/>
        <x:expect port="xproc-result">
            <x:label>x:expect[@port][not(@test)][not(@select)] with multiple child nodes
                automatically wraps each node in a document node. The sequence of document nodes is
                the expected result.</x:label>
            <node1/>
            <!-- node2 -->
            <node3/>
            <?node4?>
            <x:text>node 5</x:text>
        </x:expect>
        <x:expect port="xproc-result" test="$x:document-properties?(QName('', 'content-type'))"
            select="(
            'application/xml',
            'application/xml',
            'application/xml',
            'application/xml',
            'text/plain'
            )">
            <x:label>The content type is application/xml, except that the text node is
                text/plain</x:label>
        </x:expect>
    </x:scenario>
    <x:scenario label="When x:option has multiple child nodes and also has select='/'">
        <x:call step="optinfo:option-value">
            <x:option name="opt" select="/" as="document-node()">
                <node1/>
                <!-- node2 -->
                <node3/>
                <?node4?>
                <x:text>node 5</x:text>
            </x:option>
        </x:call>
        <x:expect port="xproc-result" result-type="document-node()" test="count($x:result)"
            select="1">
            <x:label>the option-value step returns one document node. (Wrapping occurs in XSpec due
                to @select.)</x:label>
        </x:expect>
        <x:expect port="xproc-result"
            label="x:expect[@port][not(@test)] can use select='/' to wrap all the children"
            select="/">
            <node1/>
            <!-- node2 -->
            <node3/>
            <?node4?>
            <x:text>node 5</x:text>
        </x:expect>
    </x:scenario>
    <x:scenario label="When x:option[@select] selects multiple nodes, even at different tree levels">
        <x:call step="optinfo:option-value">
            <x:option name="opt" select="//descendant" as="element(descendant)+">
                <level1>
                    <level2>
                        <descendant level="2"/>
                        <level3>
                            <descendant level="3"/>
                        </level3>
                    </level2>
                </level1>
            </x:option>
        </x:call>
        <x:expect port="xproc-result" result-type="document-node()+" test="count($x:result)"
            select="2">
            <x:label>the option-value step returns a sequence of document nodes, one for each item
                in the original sequence. (Wrapping is done at output port.)</x:label>
        </x:expect>
        <x:expect port="xproc-result" select="//descendant">
            <x:label>x:expect[@port][not(@test)][@select] in the same format automatically wraps
                each selected node in a document node. The sequence of document nodes is the
                expected result.</x:label>
            <level1>
                <level2>
                    <descendant level="2"/>
                    <level3>
                        <descendant level="3"/>
                    </level3>
                </level2>
            </level1>
        </x:expect>
        <x:expect label="Confirm the result without using @select" port="xproc-result">
            <descendant level="2"/>
            <descendant level="3"/>
        </x:expect>
    </x:scenario>
    <x:scenario label="When opt is a number">
        <x:call step="optinfo:option-value">
            <x:option name="opt" select="1" as="xs:integer"/>
        </x:call>
        <x:like label="verify JSON content type for one item"/>
        <x:expect label="the result is the number" port="xproc-result" select="1"/>
    </x:scenario>
    <x:scenario label="When opt is an array">
        <x:call step="optinfo:option-value">
            <x:option name="opt" select="[1, 2]" as="array(*)"/>
        </x:call>
        <x:like label="verify JSON content type for one item"/>
        <x:expect label="the result is the array" port="xproc-result" select="[1, 2]"/>
    </x:scenario>
    <x:scenario label="When opt is a map">
        <x:call step="optinfo:option-value">
            <x:option name="opt" select="map{1: 2}" as="map(*)"/>
        </x:call>
        <x:like label="verify JSON content type for one item"/>
        <x:expect label="the result is the map" port="xproc-result" select="map{1: 2}"/>
    </x:scenario>
    <x:scenario label="When opt is a string (which gets converted to application/json)">
        <x:call step="optinfo:option-value">
            <x:option name="opt" select="'one'" as="xs:string"/>
        </x:call>
        <x:like label="verify JSON content type for one item"/>
        <x:expect label="the result is the string" port="xproc-result" select="'one'"/>
    </x:scenario>
    <x:scenario label="If an option name duplicates an XSpec variable name">
        <x:call step="optinfo:option-value">
            <x:option name="opt" as="element(xproc-option)"><xproc-option/></x:option>
        </x:call>
        <x:variable name="opt"><xspec-variable/></x:variable>
        <x:expect label="there is no conflict; the option has its value" port="xproc-result">
            <xproc-option/>
        </x:expect>
        <x:expect label="and the variable has its own value" test="$opt">
            <xspec-variable/>
        </x:expect>
    </x:scenario>
    <x:scenario label="If an option name is literally 'name'">
        <x:call step="optinfo:option-named-name">
            <x:option name="name" select="'option-value'" as="xs:string"/>
        </x:call>
        <x:expect label="the result is the value from x:option" port="xproc-result"
            select="'option-value'"/>
    </x:scenario>

    <x:scenario shared="yes" label="verify result document">
        <x:expect label="and the option-value step returns the value" port="xproc-result">
            <document/>
        </x:expect>
    </x:scenario>
    <x:scenario shared="yes" label="verify that node is an element">
        <x:expect label="The option the test target sees is an element" port="node-type"
            select="['element']"/>
    </x:scenario>
    <x:scenario shared="yes" label="verify that node is a document node">
        <x:expect label="The option the test target sees is a document node" port="node-type"
            select="['document node']"/>
    </x:scenario>
    <x:scenario shared="yes" label="verify JSON content type for one item">
        <x:expect label="the content type is application/json" port="xproc-result"
            test="$x:document-properties?(QName('', 'content-type'))" select="'application/json'"/>
    </x:scenario>
</x:description>
