<?xml version="1.0" encoding="UTF-8"?>
<x:description xmlns:svrl="http://purl.oclc.org/dsdl/svrl"
    xmlns:x="http://www.jenitennison.com/xslt/xspec" schematron="schematron-severity.sch"
    xml:base="schematron/">
    <x:param name="Q{http://dmaus.name/ns/2023/schxslt}default-severity" select="'warning'"/>
    <x:param name="Q{http://dmaus.name/ns/2023/schxslt}severity-threshold" select="'warning'"/>
    <x:scenario label="When default severity is 'warning' and threshold is 'warning'">
        <x:context>
            <root>
                <error/>
                <warning/>
                <info/>
                <custom-severity/>
                <default-severity/>
                <dynamic-severity/>
            </root>
        </x:context>
        <x:scenario label="info-severity assertions are skipped">
            <x:expect-assert id="err"/>
            <x:expect-assert id="warn"/>
            <x:expect-not-assert id="info"/>
            <x:expect-assert id="default"/>
            <x:expect-assert id="custom"/>
            <x:expect-not-assert id="dynamic"/>
        </x:scenario>
    </x:scenario>
</x:description>
